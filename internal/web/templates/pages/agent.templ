package pages

import "github.com/raphi011/knowhow/internal/web/templates"

// AgentConversation represents a conversation in the sidebar.
type AgentConversation struct {
	ID    string
	Title string
}

// AgentMessage represents a message to render.
type AgentMessage struct {
	Role    string // "user" or "assistant"
	Content string
}

// AgentPageData holds data for the agent chat page.
type AgentPageData struct {
	Locale         string
	Theme          string
	VaultID        string
	ConversationID string
	Conversations  []AgentConversation
	Messages       []AgentMessage
	T              func(string) string
}

// AgentPage renders the agent chat interface.
templ AgentPage(data AgentPageData) {
	@templates.Layout(templates.LayoutData{
		Title:    data.T("nav.agent"),
		Locale:   data.Locale,
		Theme:    data.Theme,
		LoggedIn: true,
		T:        data.T,
	}) {
		<div class="flex h-[calc(100vh-8rem)] gap-4">
			<!-- Conversation sidebar -->
			<aside class="w-56 shrink-0 overflow-y-auto rounded-lg border border-border dark:border-border-dark p-2">
				<form method="POST" action="/hx/agent/new" class="mb-2">
					<input type="hidden" name="vault" value={ data.VaultID }/>
					<button
						type="submit"
						hx-post="/hx/agent/new"
						hx-target="#chat-area"
						class="w-full rounded-md bg-primary-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-primary-700"
					>
						+ New chat
					</button>
				</form>
				<ul class="space-y-0.5" id="conversation-list">
					for _, conv := range data.Conversations {
						<li>
							<a
								href={ templ.SafeURL("/agent?conv=" + conv.ID) }
								class={ "block truncate rounded px-2 py-1 text-sm hover:bg-gray-100 dark:hover:bg-gray-800",
									templ.KV("bg-primary-50 dark:bg-primary-900/20 text-primary-700 dark:text-primary-300", conv.ID == data.ConversationID),
									templ.KV("text-muted", conv.ID != data.ConversationID) }
							>
								{ conv.Title }
							</a>
						</li>
					}
				</ul>
			</aside>

			<!-- Chat area -->
			<div id="chat-area" class="flex min-w-0 flex-1 flex-col">
				<!-- Messages -->
				<div id="messages" class="flex-1 overflow-y-auto space-y-4 pb-4">
					for _, msg := range data.Messages {
						@agentMessage(msg)
					}
				</div>

				<!-- Streaming response target -->
				<div id="agent-response" class="hidden"></div>

				<!-- Input -->
				<div class="border-t border-border dark:border-border-dark pt-4">
					<form id="chat-form" class="flex gap-2">
						<input type="hidden" name="vault" value={ data.VaultID }/>
						<input type="hidden" name="conversationId" value={ data.ConversationID }/>
						<input
							type="text"
							name="content"
							placeholder="Ask the agent..."
							autofocus
							class="flex-1 rounded-md border border-border dark:border-border-dark bg-transparent px-3 py-2 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500"
						/>
						<button
							type="submit"
							class="rounded-md bg-primary-600 px-4 py-2 text-sm font-medium text-white hover:bg-primary-700"
						>
							Send
						</button>
					</form>
				</div>
			</div>
		</div>
		<script src="/static/js/agent.js"></script>
	}
}

templ agentMessage(msg AgentMessage) {
	if msg.Role == "user" {
		<div class="flex justify-end">
			<div class="max-w-[70%] rounded-lg bg-primary-600 px-4 py-2 text-sm text-white">
				{ msg.Content }
			</div>
		</div>
	} else {
		<div class="flex justify-start">
			<div class="prose prose-sm dark:prose-invert max-w-[70%] rounded-lg bg-gray-100 dark:bg-gray-800 px-4 py-2 text-sm">
				@templ.Raw(msg.Content)
			</div>
		</div>
	}
}
