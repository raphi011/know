# Know Environment Configuration
# Copy to .env and customize for your setup

# =============================================================================
# SurrealDB Connection
# =============================================================================
SURREALDB_URL=ws://localhost:4002/rpc
SURREALDB_NAMESPACE=knowledge
SURREALDB_DATABASE=graph
SURREALDB_USER=root
SURREALDB_PASS=root
SURREALDB_AUTH_LEVEL=root

# For local (launchd) SurrealDB with --unauthenticated:
# SURREALDB_URL=ws://localhost:8000/rpc
# SURREALDB_AUTH_LEVEL=none
# KNOW_NO_AUTH=true

# =============================================================================
# LLM Configuration (for ask, render, extract-graph)
# =============================================================================
# Provider: none | ollama | openai | anthropic | bedrock | googleai
KNOW_LLM_PROVIDER=ollama
KNOW_LLM_MODEL=qwen2.5:1.5b

# =============================================================================
# Embedding Configuration
# =============================================================================
# Provider: none | ollama | openai | anthropic | bedrock | googleai
KNOW_EMBED_PROVIDER=googleai
KNOW_EMBED_MODEL=gemini-embedding-001
KNOW_EMBED_DIMENSION=768

# =============================================================================
# Provider-Specific Settings
# =============================================================================

# Google AI (for Gemini embeddings and LLM)
# GOOGLE_AI_API_KEY=...

# Anthropic (LLM via Anthropic API, embeddings via Voyage AI)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...

# Ollama (local models)
# OLLAMA_HOST=http://localhost:11434

# Tavily (web search for agent)
# TAVILY_API_KEY=tvly-...

# AWS Bedrock (Claude models only for LLM, see bedrock-setup.sh for Teleport setup)
# KNOW_BEDROCK_EMBED_MODEL_PROVIDER=amazon     # For embedding inference profiles
# KNOW_TLS_SKIP_VERIFY=false                   # Skip TLS verification for local Teleport proxy
# AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=...                           # Set by Teleport proxy
# AWS_SECRET_ACCESS_KEY=...                       # Set by Teleport proxy
# AWS_CA_BUNDLE=...                               # Set by Teleport proxy
# HTTPS_PROXY=...                                 # Set by Teleport proxy

# =============================================================================
# Chunking Configuration
# =============================================================================
# Tune chunk sizes to match your embedding model's context window.
# Defaults target models with ~1500+ token context (MaxSize 4000 chars ≈ 1000 tokens).
# For mxbai-embed-large (512 token max sequence length), use: THRESHOLD=1200 TARGET=1000 MAX=1500
# KNOW_CHUNK_THRESHOLD=6000
# KNOW_CHUNK_TARGET_SIZE=3000
# KNOW_CHUNK_MAX_SIZE=4000
#
# Max chars per embedding API call (0 = no limit). When set, ChunkMaxSize and
# ChunkTargetSize are automatically capped to fit within this limit (reserving
# ~250 chars for contextual prefix). Also serves as a hard safety net at embed time.
# Cohere Embed v3 on Bedrock: 2048
# KNOW_EMBED_MAX_INPUT_CHARS=2048

# =============================================================================
# Server Settings
# =============================================================================
KNOW_INGEST_CONCURRENCY=4
KNOW_LOG_FILE=/tmp/know.log
KNOW_LOG_LEVEL=INFO

# =============================================================================
# Web UI (built-in Templ + HTMX, served by know-server)
# =============================================================================
# The web UI is embedded in the server binary. No separate process needed.
# Login with an API token at http://localhost:<port>/login
