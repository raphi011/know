# Knowhow Environment Configuration
# Copy to .env and customize for your setup

# =============================================================================
# SurrealDB Connection
# =============================================================================
SURREALDB_URL=ws://localhost:8000/rpc
SURREALDB_NAMESPACE=knowledge
SURREALDB_DATABASE=graph
SURREALDB_USER=root
SURREALDB_PASS=root
SURREALDB_AUTH_LEVEL=root

# =============================================================================
# LLM Configuration (for ask, render, extract-graph)
# =============================================================================
# Provider: none | ollama | openai | anthropic | bedrock | googleai
KNOWHOW_LLM_PROVIDER=anthropic
KNOWHOW_LLM_MODEL=claude-sonnet-4-20250514

# =============================================================================
# Embedding Configuration
# =============================================================================
# Provider: none | ollama | openai | anthropic | bedrock | googleai
KNOWHOW_EMBED_PROVIDER=googleai
KNOWHOW_EMBED_MODEL=gemini-embedding-001
KNOWHOW_EMBED_DIMENSION=768

# =============================================================================
# Provider-Specific Settings
# =============================================================================

# Google AI (for Gemini embeddings and LLM)
# GOOGLE_AI_API_KEY=...

# Anthropic (LLM via Anthropic API, embeddings via Voyage AI)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...

# Ollama (local models)
# OLLAMA_HOST=http://localhost:11434

# AWS Bedrock (see bedrock-setup.sh for Teleport setup)
# KNOWHOW_BEDROCK_MODEL_PROVIDER=anthropic        # For LLM inference profiles
# KNOWHOW_BEDROCK_EMBED_MODEL_PROVIDER=amazon     # For embedding inference profiles
# AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=...                           # Set by Teleport proxy
# AWS_SECRET_ACCESS_KEY=...                       # Set by Teleport proxy
# AWS_CA_BUNDLE=...                               # Set by Teleport proxy
# HTTPS_PROXY=...                                 # Set by Teleport proxy

# =============================================================================
# Server Settings
# =============================================================================
KNOWHOW_INGEST_CONCURRENCY=4
KNOWHOW_LOG_FILE=/tmp/knowhow.log
KNOWHOW_LOG_LEVEL=INFO

# =============================================================================
# Web Frontend (Next.js)
# =============================================================================

# PostgreSQL (for web app — runs via docker-compose on port 5433)
DATABASE_URL=postgresql://app:app@localhost:5433/app_dev

# Auth.js (set DISABLE_AUTH=1 for local dev without OIDC provider)
NEXTAUTH_SECRET=dev-secret-not-for-production-use-only
NEXTAUTH_URL=http://localhost:3000
DISABLE_AUTH=1

# OIDC Provider (e.g. Google, Azure AD, Keycloak)
AUTH_OIDC_ISSUER=https://accounts.google.com
AUTH_OIDC_CLIENT_ID=placeholder
AUTH_OIDC_CLIENT_SECRET=placeholder

# App
APP_URL=http://localhost:3000

# Knowhow server connections (from web → Go backend)
# Format: KNOWHOW_SERVER_<NAME>_URL + KNOWHOW_SERVER_<NAME>_TOKEN
# The web UI shows a server switcher when multiple servers are configured.
KNOWHOW_SERVER_LOCAL_URL=http://localhost:8484/query
KNOWHOW_SERVER_LOCAL_TOKEN=your-knowhow-api-token

# Example: second server
# KNOWHOW_SERVER_WORK_URL=https://knowhow.work.example.com/query
# KNOWHOW_SERVER_WORK_TOKEN=kh_work_token
