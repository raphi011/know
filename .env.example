# Knowhow Environment Configuration
# Copy to .env and customize for your setup

# =============================================================================
# SurrealDB Connection
# =============================================================================
SURREALDB_URL=ws://localhost:4002/rpc
SURREALDB_NAMESPACE=knowledge
SURREALDB_DATABASE=graph
SURREALDB_USER=root
SURREALDB_PASS=root
SURREALDB_AUTH_LEVEL=root

# =============================================================================
# LLM Configuration (for ask, render, extract-graph)
# =============================================================================
# Provider: none | ollama | openai | anthropic | bedrock | googleai
KNOWHOW_LLM_PROVIDER=ollama
KNOWHOW_LLM_MODEL=qwen2.5:1.5b

# =============================================================================
# Embedding Configuration
# =============================================================================
# Provider: none | ollama | openai | anthropic | bedrock | googleai
KNOWHOW_EMBED_PROVIDER=googleai
KNOWHOW_EMBED_MODEL=gemini-embedding-001
KNOWHOW_EMBED_DIMENSION=768

# =============================================================================
# Provider-Specific Settings
# =============================================================================

# Google AI (for Gemini embeddings and LLM)
# GOOGLE_AI_API_KEY=...

# Anthropic (LLM via Anthropic API, embeddings via Voyage AI)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...

# Ollama (local models)
# OLLAMA_HOST=http://localhost:11434

# Tavily (web search for agent)
# TAVILY_API_KEY=tvly-...

# AWS Bedrock (Claude models only for LLM, see bedrock-setup.sh for Teleport setup)
# KNOWHOW_BEDROCK_EMBED_MODEL_PROVIDER=amazon     # For embedding inference profiles
# AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=...                           # Set by Teleport proxy
# AWS_SECRET_ACCESS_KEY=...                       # Set by Teleport proxy
# AWS_CA_BUNDLE=...                               # Set by Teleport proxy
# HTTPS_PROXY=...                                 # Set by Teleport proxy

# =============================================================================
# Chunking Configuration
# =============================================================================
# Tune chunk sizes to match your embedding model's context window.
# Defaults target models with ~1500+ token context (MaxSize 4000 chars ≈ 1000 tokens).
# For mxbai-embed-large (512 token max sequence length), use: THRESHOLD=1200 TARGET=1000 MAX=1500
# KNOWHOW_CHUNK_THRESHOLD=6000
# KNOWHOW_CHUNK_TARGET_SIZE=3000
# KNOWHOW_CHUNK_MAX_SIZE=4000

# =============================================================================
# Server Settings
# =============================================================================
KNOWHOW_INGEST_CONCURRENCY=4
KNOWHOW_LOG_FILE=/tmp/knowhow.log
KNOWHOW_LOG_LEVEL=INFO

# =============================================================================
# Web Frontend (Next.js) — fully stateless, no database required
# =============================================================================

# Session encryption secret (required in production)
SESSION_SECRET=dev-secret-not-for-production-use-only

# App URL
APP_URL=http://localhost:4000

# Default server URL pre-filled on the login page (optional)
BACKEND_URL=http://localhost:4001

# Server connections are configured at login time via the web UI.
# Users enter a server URL + API token on the login page.
# The credentials are stored in an encrypted httpOnly cookie.
